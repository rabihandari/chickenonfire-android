<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/linearLayout10"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/get_location_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/get_location_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/roboto_medium"
        android:text="@string/delivery_location"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="@+id/get_location_toolbar"
        app:layout_constraintEnd_toEndOf="@+id/get_location_toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/get_location_toolbar" />

    <ImageView
        android:id="@+id/get_location_backarrow"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="4dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="@+id/get_location_toolbar"
        app:layout_constraintStart_toStartOf="@+id/get_location_toolbar"
        app:layout_constraintTop_toTopOf="@+id/get_location_toolbar"
        app:srcCompat="@drawable/back_arrow"
        android:onClick="GoBack"/>

    <ImageView
        android:id="@+id/get_location_search"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="4dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="@+id/get_location_toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:onClick="searchCalled"
        app:srcCompat="@drawable/search_button" />

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/get_location_toolbar"
        tools:context="com.zeappa.chickenonfire.GetLocationActivity" />

    <Button
        android:id="@+id/get_location_confirm_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/full_colored_button"
        android:fontFamily="@font/roboto_medium"
        android:text="@string/confirm"
        android:textAllCaps="false"
        android:stateListAnimator="@null"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:onClick="confirmLocation"/>

    <ImageView
        android:id="@+id/get_location_marker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="38dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/get_location_toolbar"
        app:srcCompat="@drawable/ic_marker_faded" />

    <ImageView
        android:id="@+id/current_location_holder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@+id/get_location_confirm_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/ic_current_location_holder" />

    <ImageView
        android:id="@+id/ic_current_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="15dp"
        android:onClick="getCurrentLocation"
        android:tint="@color/colorAccent"
        app:layout_constraintBottom_toBottomOf="@+id/current_location_holder"
        app:layout_constraintEnd_toEndOf="@+id/current_location_holder"
        app:layout_constraintStart_toStartOf="@+id/current_location_holder"
        app:layout_constraintTop_toTopOf="@+id/current_location_holder"
        app:srcCompat="@drawable/ic_current_location" />




</androidx.constraintlayout.widget.ConstraintLayout>