<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/linearLayout27"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/review_item_face"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/good_face_icon" />

    <TextView
        android:id="@+id/review_rate_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/roboto"
        android:text="@string/amazing"
        android:textColor="@android:color/black"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@+id/review_item_face"
        app:layout_constraintStart_toEndOf="@+id/review_item_face"
        app:layout_constraintTop_toTopOf="@+id/review_item_face" />

    <TextView
        android:id="@+id/review_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/roboto_light"
        android:text="(13 July 2020)"
        android:textColor="@color/myFontColor"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/review_rate_text"
        app:layout_constraintStart_toEndOf="@+id/review_rate_text"
        app:layout_constraintTop_toTopOf="@+id/review_rate_text" />

    <TextView
        android:id="@+id/review_comment"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/roboto_medium"
        android:text="Nice rest"
        android:textColor="@android:color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/review_item_face"
        app:layout_constraintTop_toBottomOf="@+id/review_rate_text" />

    <TextView
        android:id="@+id/review_username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/roboto"
        android:text="Jhon Doe"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@+id/review_comment"
        app:layout_constraintTop_toBottomOf="@+id/review_comment" />

    <ImageView
        android:id="@+id/imageView19"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="@color/ligtergrey"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/review_username"
        app:srcCompat="@color/ligtergrey" />
</androidx.constraintlayout.widget.ConstraintLayout>