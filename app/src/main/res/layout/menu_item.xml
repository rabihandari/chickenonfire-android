<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/linearLayout5"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">


    <ImageView
        android:id="@+id/menu_item_image"
        android:layout_width="120dp"
        android:layout_height="100dp"
        android:layout_marginEnd="16dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="@+id/menu_item_price"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/menu_item_title"
        app:srcCompat="@drawable/ic_default_menu_item" />

    <TextView
        android:id="@+id/menu_item_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/roboto_medium"
        android:lines="1"
        android:text="Item Title"
        android:textColor="@android:color/black"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@+id/menu_item_image"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/menu_item_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        android:textAlignment="viewStart"
        android:text="Served with roasted potato  &amp; tandoor bread, side of  hummus dip, garlic sauce, pickles, special sauce,  loukoum sweet."
        android:textColor="@color/myFontColor"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@+id/menu_item_image"
        app:layout_constraintStart_toStartOf="@+id/menu_item_title"
        app:layout_constraintTop_toBottomOf="@+id/menu_item_title"
        android:lines="2"/>

    <TextView
        android:id="@+id/menu_item_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/roboto"
        android:text="KD 3.00"
        android:textColor="@android:color/black"
        app:layout_constraintStart_toStartOf="@+id/menu_item_description"
        app:layout_constraintTop_toBottomOf="@+id/menu_item_description" />

    <ImageView
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="@color/ligtergrey"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/flavours_recyclerview" />

    <ImageView
        android:id="@+id/menu_item_disction_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="@+id/menu_item_image"
        app:layout_constraintTop_toTopOf="@+id/menu_item_image"
        app:srcCompat="@drawable/ic_discount" />

    <ImageView
        android:id="@+id/menu_item_discount_line"
        android:layout_width="55dp"
        android:layout_height="1.5dp"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@+id/menu_item_price"
        app:layout_constraintEnd_toEndOf="@+id/menu_item_price"
        app:layout_constraintStart_toStartOf="@+id/menu_item_price"
        app:layout_constraintTop_toTopOf="@+id/menu_item_price"
        app:srcCompat="@color/colorAccent" />

    <TextView
        android:id="@+id/menu_item_new_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/roboto"
        android:text="KD 2.50"
        android:textColor="@android:color/black"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@+id/menu_item_price"
        app:layout_constraintStart_toEndOf="@+id/menu_item_price"
        app:layout_constraintTop_toTopOf="@+id/menu_item_price" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/flavours_recyclerview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/menu_item_price" />

</androidx.constraintlayout.widget.ConstraintLayout>